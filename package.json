{
  "name": "wbd-tests-new",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "allure-commandline": "^2.30.0"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "wdio": "wdio run ./wdio.conf.js",
    "test:smoke": "wdio run ./wdio.conf.js --grep @smoke",
    "test:regression": "wdio run ./wdio.conf.js --grep @regression",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report"
  }
}
